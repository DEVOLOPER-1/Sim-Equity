# ══════════════════════════════════════════════════════════════════════════════
#  Sim-Equity .gitignore
#  Agent-Based Simulation of Equitable Emergency Evacuation in Île-de-France
# ══════════════════════════════════════════════════════════════════════════════

# ── Python compiled files ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.envrc

# ── Large geospatial binary files ──────────────────────────────────────────────
# OSM raw extracts (hundreds of MB; download via preparing_resources.py)
data/maps/osm_chunks_pyrosm/*.pbf
data/maps/osmnx_layers/ile-de-france-250902.osm.pbf

# Pre-built GraphML road networks (large; regenerated by preparing_resources.py)
# To commit them for easier reproducibility, comment out these lines:
data/maps/osmnx_layers/*.graphml

# GTFS zip archive (original download; individual CSVs inside IDFM-gtfs/ are tracked)
data/maps/osmnx_layers/IDFM-gtfs.zip

# Parquet files
data/maps/*.parquet
data/maps/**/*.parquet

# ── Raw NetMob25 dataset (not redistributed per data-use agreement) ────────────
# See https://netmob.org for access
data/netmob25/
data/raw/
data/private/

# ── OS-generated metadata ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE and editor files ───────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
*.sublime-project
*.sublime-workspace

# ── Build and packaging artifacts ─────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
*.whl

# ── Testing ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml

# ── Type checking ──────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.dmypy.json
dmypy.json

# ── Runtime logs (generated; not committed) ────────────────────────────────────
*.log
logs/
simulation/maps_data/downloads.log
data/maps/downloads.log

# ── Temporary and scratch files ────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.rej
.cache/

# ── uv / pip ───────────────────────────────────────────────────────────────────
# uv.lock IS committed for reproducibility — do NOT add it here.
# pip-compiled requirements (if generated separately):
requirements_compiled.txt
pip-*.txt

# ── Secrets and credentials ────────────────────────────────────────────────────
.env
.env.*
.env.local
secrets.yaml
secrets.json
credentials.json
*.pem
*.key

# ── Pre-generated simulation outputs (optional) ───────────────────────────────
# The outputs below CAN be regenerated by running the simulation pipeline.
# They are committed by default for reproducibility.
# To reduce repository size, uncomment the lines below:
#
# outputs/simulation_runs/
# outputs/agent_states/*.csv
# outputs/agent_states/simulation_outcomes/
#
# Note: outputs/figures/ is always committed (figures are small and essential
# for GitHub preview of the research).
# Note: outputs/figures/evacuation_maps/*.html is always committed
# (interactive maps are key research artifacts).



